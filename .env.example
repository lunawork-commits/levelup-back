# ============================================
# LevOne / LevelUP backend — Environment
# ============================================
# Скопируйте файл: cp .env.example .env — и заполните значения.

# === Django ===
SECRET_KEY=change-me
DEBUG=False
LANGUAGE_CODE=ru
TZ=Europe/Moscow

# === PostgreSQL (django-tenants) ===
POSTGRES_DB=levelup
POSTGRES_USER=levelup
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === VK / Telegram ===
VK_SECRET=
VK_MINI_APP_ID=53418653

# === Anthropic (AI reply suggestions, sentiment analysis) ===
ANTHROPIC_API_KEY=
# AI_PROXY_URL=   # опционально, если прокси между нами и api.anthropic.com

# === Reputation (Яндекс / 2ГИС) ===
# Глобальный рубильник — пока False, парсинг не запускается ни у кого.
REPUTATION_FETCH_ENABLED=False
# Публичный ключ partner.reviews.2gis.com. Без него 2ГИС возвращает [].
GIS_PUBLIC_KEY=

# === Загрузка медиа ===
# Лимит для видео посадочной модалки и прочих загрузок (в МБ).
MAX_UPLOAD_MB=50
